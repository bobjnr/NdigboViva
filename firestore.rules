rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Subscribers collection - authenticated users can read, only server can write
    match /subscribers/{email} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side writes allowed
    }
    
    // People collection - genealogy records (Sovereign Data - Private/Restricted)
    match /people/{personId} {
      allow read: if request.auth != null; // Registered users/editors only
      allow create: if request.resource.data.verification.consentStatus == true;
      allow update: if (request.auth != null && request.auth.uid == resource.data.verification.createdBy)
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
                    || (!resource.data.verification.recordLockDate.exists());
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public Persons Index - Published, Safe Data (Open Read)
    match /public_persons/{personId} {
      allow read: if true; // Publicly searchable
      allow write: if false; // Only written by system functions
    }

    // Submissions collection - for raw form entries before review
    match /submissions/{submissionId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.resource.data.data.consentStatus == true;
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}

