rules_version = '2';

// Firebase Storage Security Rules for Ndigbo Viva Genealogy Project
service firebase.storage {
  match /b/{bucket}/o {
    
    // Identity Documents Upload
    // Users can upload documents for their genealogy submissions
    match /identity-documents/{fileName} {
      // Allow read access to authenticated users only
      allow read: if request.auth != null;
      
      // Allow write (upload) for authenticated users with restrictions
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && request.resource.contentType.matches('image/.*|application/pdf'); // Images or PDFs only
    }
    
    // Profile Photos (if needed in future)
    match /profile-photos/{userId}/{fileName} {
      allow read: if true; // Public read for profile photos
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*'); // Images only
    }
    
    // Admin-only access to other paths
    match /{allPaths=**} {
      allow read, write: if false; // Deny all other access by default
    }
  }
}
